{
  "name": "electrobun-solid",
  "version": "1.0.0",
  "type": "module",
  "description": "Electrobun app with SolidJS and Vite HMR",
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "electrobun dev --watch",
    "hidden": "vite build && HIDDEN=1 electrobun dev",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "dev:server": "bun -e \"import { startCombinedServer } from './src/bun/server.ts'; await startCombinedServer();\"",
    "build:canary": "vite build && electrobun build --env=canary"
  },
  "dependencies": {
    "NeteaseCloudMusicApi": "^4.32.0",
    "electrobun": "1.18.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^9.1.0",
    "playwright": "^1.61.1",
    "solid-js": "^1.9.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0"
  }
}
